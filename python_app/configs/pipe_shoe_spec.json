{
  "_comment": "Pipe Shoe family TypeSpec — covers types 52/53/54/55/66/67 (D-62, D-62A, D-80)",
  "_version": "1.0.0",

  "variants": {
    "52": { "angle_wedge": true  },
    "53": { "angle_wedge": true  },
    "54": { "angle_wedge": true  },
    "55": { "angle_wedge": true  },
    "66": { "angle_wedge": false },
    "67": { "angle_wedge": false }
  },

  "sizing": {
    "_comment": "D-80 range lookup tables — each entry: lte/lt/else boundary, value v",

    "A_by_size": [
      { "lte": 8,  "v": 100 },
      { "lte": 14, "v": 130 },
      { "lte": 20, "v": 250 },
      { "else": true, "v": 300 }
    ],

    "B_by_size": [
      { "lte": 8,  "v": 0  },
      { "lte": 14, "v": 9  },
      { "else": true, "v": 12 }
    ],

    "C_by_size": [
      { "lte": 8,  "v": "200*100*5.5" },
      { "lte": 14, "v": "200*200*8"   },
      { "else": true, "v": "FB12"     }
    ],

    "D_by_size": [
      { "lte": 2.5, "v": 150 },
      { "else": true, "v": 250 }
    ],

    "E_by_size": [
      { "lt": 2, "v": 0 },
      { "else": true, "v": 50 }
    ],

    "pad_t_rule": "sch10s_wall",
    "_pad_t_comment": "Reinforcing pad thickness uses the pipe SCH.10S wall thickness for all pipe sizes handled by this shared D-80 path.",

    "pad_t_fallback_by_size": [
      { "else": true, "rule": "sch10s_wall" }
    ]
  },

  "components": [
    {
      "id":    "pad",
      "name":  "Pad_52Type",
      "when":  "pad_symbol != N/A",
      "role":  "reinforcement_pad",
      "thickness_rule": "pad_t_fallback_by_size",
      "length_expr":    "LOPS + E*2 if pipe_size <= 8 else LOPS + E*2 + 25*2",
      "_length_comment": "<=8: LOPS + E*2; >=10: LOPS + E*2 + 25*2",
      "width_expr":     "OD*pi/3",
      "_width_comment": "120-degree developed width"
    },
    {
      "id":     "wedge",
      "name":   "Angle",
      "when":   "angle_wedge",
      "role":   "angle",
      "spec":   "40*40*5",
      "length": 150,
      "qty":    2,
      "remark": "L40x40x5 side guide, CUT IN FIELD, length provisional=150"
    },
    {
      "id":     "beam",
      "name":   "H Beam",
      "when":   "C != FB12",
      "role":   "h_section",
      "spec_ref": "C",
      "length_expr": "LOPS if pipe_size <= 8 else LOPS+25*2",
      "_length_comment": "<=8: LOPS or D; 10~14: LOPS + 25*2",
      "remark_template": "CUT FROM H{C}; L=LOPS+25*2; [deep logic] 1 purchased H-beam split in half = 2 supports"
    },
    {
      "id":       "fab_bottom",
      "name":     "FB_52Type_1",
      "when":     "C == FB12",
      "role":     "generic_plate",
      "thickness": 12,
      "width_expr":  "A",
      "_width_comment": "16~24: main fabricated 12t bottom plate width = table A",
      "length_expr": "LOPS+50",
      "_length_comment": "LOPS + 25*2",
      "remark_template": "T-bottom plate: W=A, L={LOPS+50}(=LOPS+25*2), t=12"
    },
    {
      "id":       "fab_web",
      "name":     "FB_52Type_2",
      "when":     "C == FB12",
      "role":     "generic_plate",
      "thickness": 12,
      "width_expr": "HOPS",
      "length_expr": "LOPS+50",
      "_length_comment": "LOPS + 25*2",
      "remark_template": "T-vertical plate: W=HOPS, L={LOPS+50}(=LOPS+25*2), t=12"
    },
    {
      "id":       "gusset",
      "name":     "FB_52Type_3",
      "when":     "pipe_size >= 10",
      "role":     "generic_plate",
      "thickness_ref": "B",
      "length_expr":   "HOPS",
      "width_expr":    "A",
      "_width_comment": "10~24: reinforcing flat bar width = table A",
      "qty":           4,
      "remark": "height=HOPS for calculation only, not fabrication height; width=A; qty=4"
    }
  ]
}
