  "selector_rules": {
    "beam_shoe": {
      "family_id": "beam_shoe_51_56",
      "title_zh": "梁上承托選型決策",
      "title_en": "Beam-Mounted Shoe Type Selector",
      "description": "根據管材、約束需求決定 51~56 家族的適用 TYPE",

      "input_fields": [
        {
          "id": "material_isolated",
          "label_zh": "管材是否需要隔離?",
          "label_en": "Material requires isolation?",
          "type": "boolean",
          "help": "AS (Alloy Steel) 或 SS (Stainless Steel) 管線，溫度 ≤ 750°F 時需隔離"
        },
        {
          "id": "restraint_need",
          "label_zh": "約束需求",
          "label_en": "Restraint requirement",
          "type": "enum",
          "options": [
            {"value": "free", "label_zh": "自由 (無約束)", "label_en": "Free (no restraint)"},
            {"value": "lateral", "label_zh": "側向防偏", "label_en": "Lateral restraint only"},
            {"value": "guided", "label_zh": "導向 (允許軸向)", "label_en": "Guided (axial free)"},
            {"value": "fixed", "label_zh": "固定 (完全約束)", "label_en": "Fixed (full restraint)"},
            {"value": "structural_stop", "label_zh": "結構檔止 (重型)", "label_en": "Structural stop (heavy)"}
          ],
          "depends_on": {
            "field": "material_isolated",
            "when_true": {
              "available": ["fixed"],
              "note": "隔離型只有 FIXED 約束，由 guide_needed 決定 54 或 55"
            },
            "when_false": {
              "available": ["free", "lateral", "guided", "structural_stop"]
            }
          }
        },
        {
          "id": "guide_needed",
          "label_zh": "是否需要導向?",
          "label_en": "Guide mechanism needed?",
          "type": "boolean",
          "visible_when": {
            "material_isolated": true
          },
          "help": "導向機構允許管線軸向熱膨脹移動，同時限制側向偏移"
        }
      ],

      "decision_tree": [
        {
          "condition": {"material_isolated": true, "guide_needed": true},
          "result": "55",
          "reason_zh": "隔離固定 + 導向：D-81 Shoe+Clamp+Gasket + Guide",
          "reason_en": "Isolated fixed + guided: D-81 interface with guide bars"
        },
        {
          "condition": {"material_isolated": true, "guide_needed": false},
          "result": "54",
          "reason_zh": "隔離固定：D-81 Shoe+Clamp+Gasket + 側框",
          "reason_en": "Isolated fixed: D-81 interface with side frame"
        },
        {
          "condition": {"material_isolated": false, "restraint_need": "free"},
          "result": "51",
          "reason_zh": "自由承托：自有 80° 鞍座，無約束",
          "reason_en": "Free support: self-contained 80° saddle, no restraint"
        },
        {
          "condition": {"material_isolated": false, "restraint_need": "lateral"},
          "result": "52",
          "reason_zh": "側向防偏：D-80 Shoe + Retainer 板",
          "reason_en": "Lateral restraint: D-80 Shoe with retainer plates"
        },
        {
          "condition": {"material_isolated": false, "restraint_need": "guided"},
          "result": "53",
          "reason_zh": "軸向導向：D-80 Shoe + Guide 導向條",
          "reason_en": "Guided: D-80 Shoe with guide bars"
        },
        {
          "condition": {"material_isolated": false, "restraint_need": "structural_stop"},
          "result": "56",
          "reason_zh": "結構檔止：自有 MEMBER C 結構框架，3mm 間隙側板",
          "reason_en": "Structural stop: self-contained MEMBER C frame, 3mm gap side plates"
        }
      ],

      "fallback": {
        "result": "51",
        "reason_zh": "預設推薦：最簡單的自由承托",
        "reason_en": "Default: simplest free support"
      }
    }
  },

