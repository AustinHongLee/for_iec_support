  "status_definitions": {
    "documented": {
      "label_zh": "已分析",
      "label_en": "Documented",
      "color": "#4CAF50",
      "criteria": "有 .md 分析文件且檔案確實存在於磁碟",
      "badge_style": "bold"
    },
    "cataloged": {
      "label_zh": "已建檔",
      "label_en": "Cataloged",
      "color": "#2196F3",
      "criteria": "有名稱 (name_zh 或 name_en)，尚無 .md 分析文件",
      "badge_style": "normal"
    },
    "placeholder": {
      "label_zh": "預留",
      "label_en": "Placeholder",
      "color": "#9E9E9E",
      "criteria": "僅有 type_id，空白預留位",
      "badge_style": "dim"
    }
  },

  "status_rules": {
    "principle": "狀態反映使用者在此 App 能看到什麼，不反映 VBA 端實作狀態",
    "determination_logic": [
      "1. doc_file 存在且磁碟有對應 .md → documented",
      "2. 磁碟有符合命名慣例的 .md 但 catalog 未登錄 → 自動補 doc_file → documented",
      "3. 有 name_zh 或 name_en → cataloged",
      "4. 其餘 → placeholder"
    ],
    "integrity_checks": [
      "doc_file 指向不存在的檔案 → 清空 doc_file + 降級",
      "status 只允許三種值，其他一律重新判定",
      "type_id 和 category 為必要欄位"
    ]
  },

