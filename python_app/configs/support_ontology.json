  "standards": [
    {
      "id": "iec",
      "label": "IEC (International Engineering)",
      "is_default": true,
      "description": "本案主要設計標準，Type 01~120 + M/N 系列",
      "naming_convention": "TYPE-{number}",
      "unit_system": "imperial (inch, lb)",
      "catalog_file": "type_catalog.json",
      "note": "目前唯一載入的標準"
    }
  ],

  "standards_extension_guide": {
    "purpose": "未來擴充其他設計公司標準時的對應規則",
    "workflow": [
      "1. 在 standards[] 新增一筆，指定 id / label / catalog_file",
      "2. 建立該公司專屬的 catalog JSON (或共用 type_catalog.json 加 standard 欄位)",
      "3. 在 type_mapping 中建立 IEC ↔ 該公司的 type 對照表",
      "4. 在 unit_overrides 中定義單位換算 (e.g. mm → inch)",
      "5. 在 constant_deltas 中定義常數差異 (e.g. 不同的 HOPS 計算)"
    ],
    "type_mapping_example": {
      "company_x": {
        "PS-101": {"iec_equivalent": "51", "note": "類似 TYPE-51 自由承托，但 saddle 角 90°"},
        "PS-102": {"iec_equivalent": "52", "note": "類似 TYPE-52 但 retainer 用角鋼非平板"},
        "PS-201": {"iec_equivalent": "54", "note": "隔離型，gasket 厚度不同 (6mm vs 3mm)"}
      }
    },
    "unit_overrides_example": {
      "company_x": {
        "length": {"from": "mm", "to": "inch", "factor": 0.03937},
        "force": {"from": "kgf", "to": "lb", "factor": 2.20462}
      }
    },
    "constant_deltas_example": {
      "company_x": {
        "shoe_angle": {"iec": 120, "company": 90, "unit": "deg"},
        "gasket_thickness": {"iec": 3, "company": 6, "unit": "mm"}
      }
    }
  }
}
